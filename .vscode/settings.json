{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": true,
    "source.organizeImports": true
  },
  "dart.lineLength": 100,
  "files.exclude": {
    "**/.dart_tool": true,
    "**/.idea": true,
    "**/.firebase": true,
    "**/build": true,
    "**/.flutter-plugins": true,
    "**/.flutter-plugins-dependencies": true,
    "**/.packages": true,
    "**/*.g.dart": false
  },
  "files.watcherExclude": {
    "**/.dart_tool/**": true,
    "**/.idea/**": true,
    "**/.firebase/**": true,
    "**/build/**": true,
    "**/.flutter-plugins/**": true,
    "**/.flutter-plugins-dependencies/**": true,
    "**/.packages/**": true
  }
}
