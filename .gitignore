# ================================
# GoPlus System - .gitignore
# ================================

# =============================
# FIREBASE
# =============================
# Functions
firebase/functions/node_modules/
firebase/functions/npm-debug.log*
firebase/functions/lib/
firebase/functions/.runtimeconfig.json
firebase/node_modules
functions/node_modules

# Firebase Hosting
firebase/hosting/node_modules/

# Firebase Cache y Logs
.firebase/
firebase-debug.log*
firestore-debug.log*
database-debug.log*
pubsub-debug.log*
firebase-functions-debug.log*

# Firebase emulators
ui-debug.log
firebase-emulators-debug.log*

# Firebase Service Account Keys (SENSIBLES - NO INCLUIR)
**/service-account-*.json
**/firebase-adminsdk-*.json

# =============================
# FLUTTER
# =============================
# Build outputs
**/build/
**/web/build/

# Flutter tools
**/.dart_tool/
**/.packages
**/.metadata
**/.pub-cache/
**/.pub/
**/pubspec.lock

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
# Regenerate lock files with flutter packages get

# Coverage
coverage/
**/coverage/

# Flutter widgets tests coverage
**/test/.test_coverage.dart

# =============================
# MELOS (Monorepo Management)
# =============================
.melos_work/
.packages_gen/
melos_bootstrap.dart

# =============================
# ANDROID
# =============================
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks

# Android signing files
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# Android keystore files (SENSIBLES)
**/android/app/*.keystore
**/android/app/key.properties

# =============================
# IOS
# =============================
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/.vagrant/
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# iOS signing and provisioning (SENSIBLES)
**/ios/**/*.mobileprovision
**/ios/**/*.p12
**/ios/**/*.cer

# =============================
# WEB
# =============================
**/web/packages/
**/web/.packages
**/web/pubspec.lock
**/web/.dart_tool/
**/web/build/

# Web generated files (mantener index.html base)
**/web/manifest.json

