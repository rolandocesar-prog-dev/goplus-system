# ================================
# GoPlus System - .gitignore
# ================================

# =============================
# FIREBASE
# =============================
# Functions
firebase/functions/node_modules/
firebase/functions/npm-debug.log*
firebase/functions/lib/
firebase/functions/.runtimeconfig.json
firebase/node_modules
functions/node_modules

# Firebase Hosting
firebase/hosting/node_modules/

# Firebase Cache y Logs
.firebase/
firebase-debug.log*
firestore-debug.log*
database-debug.log*
pubsub-debug.log*
firebase-functions-debug.log*

# Firebase emulators
ui-debug.log
firebase-emulators-debug.log*

# =============================
# FLUTTER
# =============================
# Build outputs
**/build/
**/web/build/

# Flutter tools
**/.dart_tool/
**/.packages
**/.metadata
**/.pub-cache/
**/.pub/
**/pubspec.lock

# Flutter/Dart/Pub related
# Libraries should not include pubspec.lock, per https://dart.dev/guides/libraries/private-files#pubspeclock.
# Regenerate lock files with flutter packages get

# Coverage
coverage/
**/coverage/

# Flutter widgets tests coverage
**/test/.test_coverage.dart

# =============================
# ANDROID
# =============================
**/android/**/gradle-wrapper.jar
**/android/.gradle
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks

# Android signing files
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# =============================
# IOS
# =============================
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/*sync/
**/ios/**/.sconsign.dblite
**/ios/**/.tags*
**/ios/**/.vagrant/
**/ios/**/DerivedData/
**/ios/**/Icon?
**/ios/**/Pods/
**/ios/**/.symlinks/
**/ios/**/profile
**/ios/**/xcuserdata
**/ios/.generated/
**/ios/Flutter/.last_build_id
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/ephemeral/
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# =============================
# WEB
# =============================
**/web/packages/
**/web/.packages
**/web/pubspec.lock
**/web/.dart_tool/
**/web/build/

# =============================
# ARCHIVOS DE CONFIGURACIÓN SENSIBLES
# =============================
# Environment variables
.env
.env.local
.env.development
.env.staging
.env.production
.env.test

# Firebase config files (if they contain sensitive data)
# Descomenta estas líneas si tus archivos contienen claves sensibles:
# **/android/app/google-services.json
# **/ios/Runner/GoogleService-Info.plist
# **/web/index.html

# API Keys y secrets
secrets.dart
api_keys.dart
**/lib/config/secrets.dart

# Database URLs y endpoints privados
**/lib/config/endpoints.dart

# =============================
# IDE Y EDITORES
# =============================
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Android Studio
.idea/
*.iml
*.ipr
*.iws

# IntelliJ
*.iml
*.ipr
*.iws
.idea/

# =============================
# SISTEMA OPERATIVO
# =============================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================
# LOGS Y TEMPORALES
# =============================
# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Dependency directories
node_modules/
**/node_modules

# =============================
# TESTING Y CI/CD
# =============================
# Test reports
test-results/
reports/

# Jest coverage
coverage/

# Temporary folders
tmp/
temp/

# =============================
# DOCUMENTACIÓN Y ASSETS PESADOS
# =============================
# Assets grandes (descomenta si tienes archivos muy pesados)
# **/assets/videos/
# **/assets/animations/large/

# Documentación generada
docs/api/
docs/build/

# =============================
# PERSONALIZACIONES GOPLUS
# =============================
# Scripts de build temporales
tools/temp/
tools/logs/

# Configuraciones locales de desarrollo
local.properties
dev.properties

# Archivos de backup
*.backup
*.bak
*.tmp

# Archivos específicos del proyecto que no deberían estar en git
# (añade aquí archivos específicos de tu proyecto)