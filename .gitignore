# =============================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE_BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# =============================
# LOGS Y TEMPORALES
# =============================
# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Dependency directories
node_modules/
**/node_modules

# =============================
# TESTING Y CI/CD
# =============================
# Test reports
test-results/
reports/

# Jest coverage
coverage/

# Temporary folders
tmp/
temp/

# GitHub Actions artifacts
.github/workflows/artifacts/

# =============================
# DOCUMENTACIÓN Y ASSETS PESADOS
# =============================
# Assets grandes (descomenta si tienes archivos muy pesados)
# **/assets/videos/large/
# **/assets/animations/heavy/
# **/assets/images/raw/

# Documentación generada automáticamente
docs/api/generated/
docs/build/
doc/api/

# =============================
# DEPENDENCIAS Y PACKAGES
# =============================
# Pub dependencies (Flutter)
.packages
.pub/
.dart_tool/packages

# NPM/Node dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================
# PERSONALIZACIONES GOPLUS
# =============================
# Scripts de build temporales
tools/temp/
tools/logs/
tools/output/

# Configuraciones locales de desarrollo
local.properties
dev.properties
local.env

# Archivos de backup
*.backup
*.bak
*.tmp
*.orig

# Archivos específicos del proyecto que no deberían estar en git
# Cache de herramientas
.tool-cache/
.download-cache/

# Configuraciones específicas de usuario
user.properties
local_config.dart

# Archivos de prueba temporales
test_output/
integration_test/screenshots/
test/fixtures/temp/

# =============================
# ARCHIVOS QUE SÍ SE INCLUYEN
# =============================
# IMPORTANTE: Los siguientes archivos SÍ deben estar en el repositorio:
# 
# Firebase Config (NO sensibles):
# - **/android/app/google-services.json
# - **/ios/Runner/GoogleService-Info.plist  
# - **/web/index.html
# - firebase.json
# - apps/*/firebase.json
# - lib/firebase_options.dart
#
# Configuración de proyecto:
# - pubspec.yaml (todos)
# - analysis_options.yaml
# - melos.yaml
# - README.md files
# - .vscode/tasks.json
# - .vscode/launch.json
# 
# Scripts y herramientas:
# - tools/scripts/**/*.ps1
# - tools/scripts/**/*.sh
#
# NOTA: Si algún archivo Firebase contiene claves sensibles reales,
# muévelo a la sección de archivos sensibles arriba.