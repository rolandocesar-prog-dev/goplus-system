# =============================
# Environment variables
.env
.env.local
.env.development
.env.staging
.env.production
.env.test

# API Keys y secrets (SOLO ARCHIVOS SENSIBLES)
secrets.dart
**/lib/config/api_keys_prod.dart
**/lib/config/endpoints_prod.dart
**/lib/config/secrets_prod.dart

# Database URLs y endpoints privados (SOLO PRODUCCIÓN)
**/lib/config/prod_endpoints.dart

# =============================
# IDE Y EDITORES
# =============================
# VS Code (incluir configuración base del proyecto)
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Android Studio
.idea/
*.iml
*.ipr
*.iws

# IntelliJ
*.iml
*.ipr
*.iws
.idea/

